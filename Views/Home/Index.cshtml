@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h1 class="display-4">Bienvenido al Sistema de Adopción de Mascotas 🐾</h1>
        <p class="lead">Gestiona mascotas, adopciones y adoptantes con facilidad.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-4 text-center mb-3">
            <a href="/Mascotas/Create" class="btn btn-primary btn-lg w-100">Registrar Nueva Mascota</a>
        </div>
        <div class="col-md-4 text-center mb-3">
            <a href="/Adopciones/Crear" class="btn btn-success btn-lg w-100">Asignar Mascota</a>
        </div>
        <div class="col-md-4 text-center mb-3">
            <a href="/Adopciones/Listado" class="btn btn-outline-secondary btn-lg w-100">Ver Adopciones</a>
        </div>
        <div class="col-md-4 text-center mb-3">
            <a href="/Adoptantes/Create" class="btn btn-info btn-lg w-100">Registrar Adoptante</a>
        </div>

    </div>
</div>
