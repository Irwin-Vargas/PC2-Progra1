@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Sistema de Adopción de Mascotas 🐾</h1>
        <p class="lead">Gestiona mascotas, adoptantes y adopciones de forma fácil y rápida.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 justify-content-center">
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Registrar Mascota</h5>
                    <p class="card-text">Agrega una nueva mascota disponible para adopción.</p>
                    <a href="/Mascotas/Create" class="btn btn-primary w-100">Ir al formulario</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Registrar Adoptante</h5>
                    <p class="card-text">Crea el perfil de una persona interesada en adoptar.</p>
                    <a href="/Adoptantes/Create" class="btn btn-info w-100">Registrar adoptante</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Asignar Mascota</h5>
                    <p class="card-text">Relaciona una mascota disponible con un adoptante.</p>
                    <a href="/Adopciones/Crear" class="btn btn-success w-100">Asignar</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Ver Adopciones</h5>
                    <p class="card-text">Consulta el historial de todas las adopciones realizadas.</p>
                    <a href="/Adopciones/Listado" class="btn btn-outline-secondary w-100">Ver listado</a>
                </div>
            </div>
        </div>
    </div>
</div>
